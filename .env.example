# =============================================================================
# .env.example — AO Deportes (apps/mobile — Expo)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase
# EXPO_PUBLIC_* variables are inlined by Expo's Metro bundler at build time.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Web app URL — used by services/avatar.ts to proxy avatar uploads through
# the Next.js API (/api/avatar/upload).
# Development : http://localhost:3000
# Production  : https://<your-vercel-project>.vercel.app  (or your custom domain)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_WEB_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Push notifications — OneSignal
# NOTE: The OneSignal App ID is consumed server-side only (apps/web).
# The mobile app registers Expo push tokens directly; it does NOT use the
# OneSignal SDK. This variable is kept here for reference only.
# ---------------------------------------------------------------------------
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-uuid  # (not used in mobile code)
