# =============================================================================
# .env.example — AO Deportes (apps/web)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Email provider — Resend
# Get your key at https://resend.com
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here

# Sender address — must match a verified domain in the Resend dashboard.
# Domain aodeporte.com is already verified (region: us-east-1).
# Use onboarding@resend.dev ONLY for local dev without domain access.
RESEND_FROM_EMAIL=noreply@aodeporte.com

# ---------------------------------------------------------------------------
# Push notifications — OneSignal
# Get these values from OneSignal → Settings → Keys & IDs
# ---------------------------------------------------------------------------
ONESIGNAL_APP_ID=your-onesignal-app-uuid
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ---------------------------------------------------------------------------
# App URL (used for building ticket links in email templates)
# Development : http://localhost:3000
# Preview     : https://<branch>.vercel.app  (set automatically by Vercel)
# Production  : https://aodeporte.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# AI — Anthropic (Claude)
# Required for: daily newsletter auto-generation (cron) and diagnostic
# integrated-result text synthesis on the athlete profile page.
# Get your key at https://console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ---------------------------------------------------------------------------
# Cron secret
# Generate a random string and set the same value in your Vercel project
# environment variables. Vercel will include it in cron request headers.
# ---------------------------------------------------------------------------
CRON_SECRET=a-long-random-secret-string-here
