# =============================================================================
# .env.example — AO Deportes (apps/mobile — Expo)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase
# EXPO_PUBLIC_* variables are inlined by Expo's Metro bundler at build time.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Push notifications — OneSignal
# Get the App ID from OneSignal → Settings → Keys & IDs
# Only EXPO_PUBLIC_ONESIGNAL_APP_ID needs to be in the client bundle.
# The REST API key is server-side only (used by apps/web, not here).
# ---------------------------------------------------------------------------
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-uuid
